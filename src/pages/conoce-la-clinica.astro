---
import Layout from '../layouts/Layout.astro';
import TopBar from '../components/TopBar.astro';
import Header from '../components/Header.astro';
import AboutHeroSection from '../components/AboutHeroSection.astro';
import TeamMembersSection from '../components/TeamMembersSection.astro';
import ValuesSection from '../components/ValuesSection.astro';
import FeatureCardsSection from '../components/FeatureCardsSection.astro';
import SpecialtiesSection from '../components/SpecialtiesSection.astro';
import FooterSection from '../components/FooterSection.astro';
---

<Layout
	title="Conoce la Clínica"
	description="Clínica dental integral en El Bosque. Más de 40 años de experiencia. Equipo especializado, tecnología de vanguardia y trato personalizado para tu bienestar dental."
>
	<TopBar />
	<Header />
	<main id="main-content">
		<AboutHeroSection />
		<TeamMembersSection />
		<ValuesSection />
		<FeatureCardsSection
			id="tecnologia"
			label="Clínica"
			title="Para una atención de calidad"
			description="En Dental Gran Avenida, queremos que ir al dentista sea una experiencia tranquila y positiva. Por eso cuidamos cada detalle para que te sientas seguro, cómodo y en buenas manos."
		/>
		<SpecialtiesSection background="white" />
	</main>
	<FooterSection />
</Layout>
